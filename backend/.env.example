# PostgreSQL接続文字列（Renderのものを使う）
DATABASE_URL=postgresql://localhost:5432/candyblast?sslmode=disable

# JWT秘密鍵（適当な乱数を生成）
JWT_SECRET=your-super-secret-key-here

# Discord Webhook（認証用）
DISCORD_WEBHOOK_AUTH=https://discord.com/api/webhooks/...

# Discord Webhook（ログイン監視用）
DISCORD_WEBHOOK_LOGIN=https://discord.com/api/webhooks/...
